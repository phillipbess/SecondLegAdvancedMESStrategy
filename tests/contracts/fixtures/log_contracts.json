{
  "family_id": "logging_contract",
  "status": "implemented",
  "base_path_marker": "Path.Combine(NinjaTrader.Core.Globals.UserDataDir, \"logs\", \"SecondLegAdvancedMES\")",
  "line_grammar": {
    "source_marker": "writer.WriteLine($\"{timestamp} | {message}\");",
    "timestamp_format_marker": "return now.ToString(\"yyyy-MM-dd HH:mm:ss.fff\", CultureInfo.InvariantCulture);"
  },
  "helper_markers": [
    "private static string JoinStructuredFields(params string[] fields)",
    "private void WriteTradeContextLog(string eventName, params string[] detailFields)",
    "private void WriteRiskEvent(string eventName, params string[] detailFields)",
    "private void WriteDebugEvent(string eventName, params string[] detailFields)"
  ],
  "header_schema_markers": [
    "writer.WriteLine($\"=== NEW RUN === {logType} ===\");",
    "writer.WriteLine($\"Strategy: SecondLegAdvanced {StrategyVersion}\");",
    "writer.WriteLine($\"RunID: {_loggingRunId}\");",
    "writer.WriteLine($\"Instrument: {Instrument?.MasterInstrument?.Name ?? \"UnknownInstrument\"}\");",
    "writer.WriteLine($\"Account: {Account?.DisplayName ?? Account?.Name ?? \"UnknownAccount\"}\");",
    "writer.WriteLine($\"Started: {DateTime.Now:yyyy-MM-dd HH:mm:ss.fff}\");",
    "writer.WriteLine($\"Schema: {DescribeLogSchema(logType)}\");",
    "writer.WriteLine($\"Vocabulary: {string.Join(\", \", GetLogVocabulary(logType))}\");"
  ],
  "entry_context_schema_markers": [
    "bar=",
    "time=",
    "state=",
    "bias=",
    "trend=",
    "session=",
    "atrRegime=",
    "atr=",
    "atrRatio=",
    "slopeAtrPct=",
    "impulseRange=",
    "impulseStrongBars=",
    "retracement=",
    "leg2Momentum=",
    "impulseMomentum=",
    "structure=",
    "signalBar=",
    "planned="
  ],
  "entry_context_ordered_markers": [
    "bar=",
    "time=",
    "state=",
    "bias=",
    "trend=",
    "session=",
    "atrRegime=",
    "atr=",
    "atrRatio=",
    "slopeAtrPct=",
    "impulseRange=",
    "impulseStrongBars=",
    "retracement=",
    "leg2Momentum=",
    "impulseMomentum=",
    "structurePart",
    "signalPart",
    "plannedEntryPart"
  ],
  "sinks": {
    "trade": {
      "schema_marker": "\"TRADE\" => \"timestamp | [EVENT] signal=<id> trade=<id> role=<entry|protective|flatten|other> qty=<n> order=<name> orderId=<id> state=<state> key=value ...\"",
      "filename_marker": "Path.Combine(_loggingBasePath, $\"Trades_{_loggingRunId}.txt\")",
      "log_type_marker": "EnsureLogHeader(_tradeLogPath, \"TRADE\");",
      "writer_marker": "WriteToLogFile(_tradeLogPath, \"TRADE\", message);",
      "writer_source": "logging",
      "event_markers": [
        "\"ENTRY_SUBMIT\"",
        "\"ENTRY_FILL\"",
        "\"EXIT_FILL\"",
        "\"EXIT_REJECTED\"",
        "\"FLATTEN_REQUEST\"",
        "\"FLATTEN_SUBMIT\"",
        "\"FLATTEN_REJECTED\"",
        "\"FLATTEN_CANCELLED\"",
        "\"FLATTEN_COMPLETE\"",
        "\"TRADE_CLOSE\"",
        "\"RECOVERY_RESOLUTION\"",
        "\"RECOVERY_RECONNECT_GRACE\"",
        "\"RECOVERY_RECONNECT_OUTCOME\"",
        "\"PROTECTIVE_REPLACE_BEGIN\"",
        "\"PROTECTIVE_REPLACE_END\"",
        "\"PROTECTIVE_REPLACE_FAIL\"",
        "\"PROTECTIVE_REPLACE_COMMIT\"",
        "\"TRANSPORT_BIND\"",
        "\"TRANSPORT_RELEASE\""
      ],
      "required_field_markers": [
        "signal=",
        "trade=",
        "role=",
        "qty=",
        "order=",
        "orderId=",
        "state="
      ],
      "callsite_markers": [
        "WriteTradeContextLog( \"ENTRY_SUBMIT\",",
        "WriteTradeLifecycleLog( \"ENTRY_FILL\",",
        "WriteTradeLifecycleLog( \"EXIT_FILL\",",
        "WriteTradeLifecycleLog( \"TRADE_CLOSE\",",
        "WriteTradeLifecycleLog( \"EXIT_REJECTED\",",
        "WriteTradeLifecycleLog( \"FLATTEN_SUBMIT\",",
        "WriteTradeContextLog( \"FLATTEN_REQUEST\",",
        "WriteTradeContextLog( \"FLATTEN_COMPLETE\",",
        "WriteTradeContextLog( \"RECOVERY_RECONNECT_GRACE\",",
        "WriteTradeContextLog(\"RECOVERY_RECONNECT_OUTCOME\",",
        "WriteTradeContextLog(\"RECOVERY_RESOLUTION\",",
        "WriteTradeContextLog( \"PROTECTIVE_REPLACE_BEGIN\",",
        "WriteTradeContextLog(\"PROTECTIVE_REPLACE_END\",",
        "WriteTradeContextLog( \"PROTECTIVE_REPLACE_FAIL\",",
        "WriteTradeContextLog( \"PROTECTIVE_REPLACE_COMMIT\",",
        "WriteTradeLifecycleLog( \"TRANSPORT_BIND\",",
        "WriteTradeLifecycleLog(\"TRANSPORT_RELEASE\","
      ],
      "exact_field_order_markers": [
        "\"ENTRY_SUBMIT\", $\"signal={_plannedEntry.SignalName}\", $\"trade={_plannedEntry.SignalName}\", $\"bias={_plannedEntry.Bias}\", $\"qty={_plannedEntry.Quantity}\", $\"entry={_plannedEntry.EntryPrice:F2}\", $\"stop={_plannedEntry.InitialStopPrice:F2}\", $\"reason={_plannedEntry.Reason}\"",
        "\"ENTRY_FILL\", order, $\"execId={executionId}\", $\"qty={quantity}\", $\"fillPrice={price:F2}\", $\"avgEntry={entryPrice:F2}\", $\"posQty={Position.Quantity}\", $\"sessionControlFlatten={sessionControlFlattenTriggered}\"",
        "\"TRADE_CLOSE\", order, $\"execId={executionId}\", $\"qty={quantity}\", $\"exitPrice={price:F2}\", $\"marketPosition={marketPosition}\", BuildLatestClosedTradeSummary().Trim()",
        "\"FLATTEN_REQUEST\", $\"qty={Math.Abs(Position.Quantity)}\", $\"reason={reason}\", $\"state={_exitState}\"",
        "\"RECOVERY_RESOLUTION\", $\"resolution={_recoveryResolution}\", $\"ctx={context}\"",
        "\"PROTECTIVE_REPLACE_BEGIN\", $\"context={context}\", $\"reason={reason}\",",
        "\"TRANSPORT_BIND\", order, $\"context={context}\",",
        "\"TRANSPORT_RELEASE\", order, $\"context={context}\","
      ],
      "notes": "Trades_ now covers entry, exit, flatten, and reconnect lifecycle breadcrumbs."
    },
    "tradesCsv": {
      "schema_marker": "TradeID,Signal,Side,Qty,Entry,EntryTime,Exit,ExitTime,PnL_USD,PnL_pts_per_ct,R,PeakProfit_pts,MaxDrawdown_pts,CapturePct,DurationMin,Reason,TrailArmPx,TrailExitPx,TOD,VolRegime,Risk_USD,SupportLevel,BreakdownDepth_pts,BreakdownLow",
      "filename_marker": "Path.Combine(_loggingBasePath, $\"TradesCsv_{_loggingRunId}.csv\")",
      "log_type_marker": "EnsureTradeCsvHeader();",
      "writer_marker": "WriteTradeCsvSummaryLine(",
      "writer_source": "logging",
      "event_markers": [
        "WriteLatestClosedTradeCsv(order, price, time);",
        "TradeID,Signal,Side,Qty,Entry,EntryTime,Exit,ExitTime",
        "PnL_USD,PnL_pts_per_ct,R,PeakProfit_pts,MaxDrawdown_pts,CapturePct"
      ],
      "notes": "TradesCsv_ is Mancini-compatible machine-readable trade summary output emitted on completed trades."
    },
    "pattern": {
      "schema_marker": "\"PATTERN\" => \"timestamp | [EVENT] bar=<index> time=<hh:mm:ss> state=<state> bias=<side> trend=<bool> session=<bool> atrRegime=<bool> atr=<value> atrRatio=<value> slopeAtrPct=<value> impulseRange=<value> impulseStrongBars=<n> retracement=<value> leg2Momentum=<value> impulseMomentum=<value> structure=<label> signalBar=<index|none> planned=<summary> | detail\"",
      "filename_marker": "Path.Combine(_loggingBasePath, $\"Patterns_{_loggingRunId}.txt\")",
      "log_type_marker": "EnsureLogHeader(_patternLogPath, \"PATTERN\");",
      "writer_marker": "WriteToLogFile(_patternLogPath, \"PATTERN\", message);",
      "writer_source": "logging",
      "event_markers": [
        "\"ENTRY_STATE\"",
        "\"ENTRY_BLOCK\"",
        "\"ENTRY_ARMED\"",
        "\"IMPULSE_QUALIFIED\""
      ],
      "state_reason_markers": [
        "TrendContextReady",
        "ImpulseQualified",
        "PullbackLeg1Qualified",
        "SeparationQualified",
        "PullbackLeg2Candidate",
        "Leg2Extended",
        "SignalBarQualified",
        "ReleaseBlockedState",
        "AdvanceResetState",
        "PromoteToManagingTrade",
        "DemoteToWaitingForTrigger"
      ],
      "block_reason_markers": [
        "SignalInvalid",
        "SecondLegTooShallow",
        "SecondLegTooDeep",
        "SecondLegTooStrong",
        "CorrectiveSideInvalid",
        "Leg2CandidateMissing",
        "RiskTooSmall",
        "StopTooWide",
        "StructureRoom",
        "InvalidPlannedEntry",
        "EntryOrderError",
        "SubmissionAuthorityBlocked",
        "ProtectiveStopRejected",
        "SessionControlFlatten"
      ]
    },
    "risk": {
      "schema_marker": "\"RISK\" => \"timestamp | [EVENT] key=value ...\"",
      "filename_marker": "Path.Combine(_loggingBasePath, $\"Risk_{_loggingRunId}.txt\")",
      "log_type_marker": "EnsureLogHeader(_riskLogPath, \"RISK\");",
      "writer_marker": "WriteRiskLog(message);",
      "writer_source": "logging",
      "event_markers": [
        "\"STOP_SUBMIT\"",
        "\"STOP_CHANGE\"",
        "\"STOP_ACK\"",
        "\"STOP_CONFIRMED\"",
        "\"STOP_CANCELLED_ACK\"",
        "\"STOP_FILLED_ACK\"",
        "\"STOP_QTY_MISMATCH\"",
        "\"DOUBLE STOP DETECTED\"",
        "\"ORPHAN_CHECK\"",
        "\"ORPHAN_SWEEP\"",
        "\"OM_HEALTH\"",
        "\"FIRST_STOP_SLA\"",
        "\"ADOPT\"",
        "\"OCO_RESUBMIT\"",
        "\"COVERAGE_STATE\"",
        "\"PROTECTIVE_COVERAGE\"",
        "\"FLATTEN_RECOVERY\"",
        "\"SUBMISSION_AUTHORITY\""
      ],
      "vocabulary_route_markers": [
        "\"RISK\" => RiskLogEvents",
        "private static readonly string[] RiskLogEvents =",
        "private void WriteRiskEvent(string eventName, params string[] detailFields)"
      ],
      "callsite_markers": [
        "WriteRiskEvent( \"STOP_SUBMIT\",",
        "WriteRiskEvent( \"STOP_CHANGE\",",
        "WriteRiskEvent( \"STOP_ACK\",",
        "WriteRiskEvent( \"STOP_CONFIRMED\",",
        "WriteRiskEvent( \"STOP_CANCELLED_ACK\",",
        "WriteRiskEvent( \"STOP_FILLED_ACK\",",
        "WriteRiskEvent( \"STOP_QTY_MISMATCH\",",
        "WriteRiskEvent( \"DOUBLE STOP DETECTED\",",
        "WriteRiskEvent( \"ORPHAN_CHECK\",",
        "WriteRiskEvent( \"ORPHAN_SWEEP\",",
        "WriteRiskEvent( \"OM_HEALTH\",",
        "WriteRiskLog( $\"[FIRST_STOP_SLA]",
        "WriteRiskEvent( \"ADOPT\",",
        "WriteRiskEvent( \"OCO_RESUBMIT\",",
        "WriteRiskEvent( \"COVERAGE_STATE\",",
        "WriteRiskEvent( \"PROTECTIVE_COVERAGE\",",
        "WriteRiskEvent( \"FLATTEN_RECOVERY\",",
        "WriteRiskEvent(\"SUBMISSION_AUTHORITY\", $\"detail={message.Trim()}\")"
      ],
      "notes": "Risk_ is a routed runtime sink with pinned header vocabulary markers, Mancini-compatible OM checklist tokens, and host routing."
    },
    "stopEvents": {
      "schema_marker": "EVENT,Context,Final,Tape,Baseline,Bar,Time",
      "filename_marker": "Path.Combine(_loggingBasePath, $\"StopEvents_{_loggingRunId}.csv\")",
      "log_type_marker": "EnsureStopEventsFile();",
      "writer_marker": "AppendStopEventCsv(",
      "writer_source": "logging",
      "event_markers": [
        "MirrorRiskMessageToStopEventsCsv(message);",
        "ShouldMirrorRiskEventToStopEvents",
        "STOP_ACK",
        "STOP_CONFIRMED",
        "FIRST_STOP_SLA"
      ],
      "notes": "StopEvents_ mirrors stop/protective risk events into the Mancini-compatible stop event CSV shape."
    },
    "debug": {
      "schema_marker": "\"DEBUG\" => \"timestamp | [EVENT] key=value ...\"",
      "filename_marker": "Path.Combine(_loggingBasePath, $\"Debug_{_loggingRunId}.txt\")",
      "log_type_marker": "EnsureLogHeader(_debugLogPath, \"DEBUG\");",
      "writer_marker": "WriteToLogFile(_debugLogPath, \"DEBUG\", message);",
      "writer_source": "runtime_host",
      "event_markers": [
        "[LOG PATHS]",
        "[LOG CLEANUP]",
        "[ENTRY_BLOCK]",
        "[FLATTEN]",
        "[FLATTEN_REPRICE]",
        "\"RECONNECT_GRACE\"",
        "\"RECONNECT_OBSERVATION\"",
        "\"POSITION_UPDATE\"",
        "\"EXIT_OP_ENQ\"",
        "\"EXIT_OP_BEGIN\"",
        "\"EXIT_OP_END\"",
        "\"EXIT_OP_RETRY\"",
        "\"EXIT_OP_DROP\"",
        "\"EXIT_OP_CARVEOUT\"",
        "\"EXIT_OP_TIMEOUT\"",
        "\"EXIT_OP_ERROR\"",
        "\"EXIT_OP_TIMEOUT_RELEASE\"",
        "\"TRANSPORT_BIND\"",
        "\"TRANSPORT_RELEASE\"",
        "\"PROTECTIVE_REPLACE_BEGIN\"",
        "\"PROTECTIVE_REPLACE_END\"",
        "\"PROTECTIVE_REPLACE_FAIL\"",
        "\"PROTECTIVE_REPLACE_COMMIT\"",
        "\"CANCEL_ALL\"",
        "\"STATE_RESTORE\"",
        "\"STATE_SAVE_ERROR\"",
        "\"STATE_RESTORE_ERROR\"",
        "\"HARNESS_STATE\""
      ],
      "callsite_markers": [
        "WriteDebugEvent( \"RECONNECT_GRACE\", \"phase=begin\",",
        "WriteDebugEvent(\"RECONNECT_OBSERVATION\", \"outcome=covered-owned\",",
        "WriteDebugEvent(\"RECONNECT_OBSERVATION\", \"outcome=pending-owned\",",
        "WriteDebugEvent( \"POSITION_UPDATE\", $\"marketPosition={marketPosition}\",",
        "WriteDebugEvent(\"EXIT_OP_ENQ\",",
        "WriteDebugEvent(\"EXIT_OP_BEGIN\",",
        "WriteDebugEvent(\"EXIT_OP_END\",",
        "WriteDebugEvent( \"EXIT_OP_RETRY\", $\"attempt={attempt}\",",
        "WriteDebugEvent(\"EXIT_OP_DROP\", $\"reason={reason}\", \"phase=finalizing\")",
        "WriteDebugEvent(\"EXIT_OP_CARVEOUT\", $\"reason={reason}\", \"phase=finalizing\", $\"qty={Position.Quantity}\")",
        "WriteDebugEvent(\"EXIT_OP_TIMEOUT\", $\"reason={reason}\", \"outcome=defer-watchdog\")",
        "WriteDebugEvent(\"EXIT_OP_ERROR\", $\"ctx={context}\", $\"msg={ex.Message}\")",
        "WriteDebugEvent(\"EXIT_OP_TIMEOUT_RELEASE\", \"reason=pending-window-expired\")",
        "WriteDebugLog($\"[FLATTEN_REPRICE]",
        "WriteDebugEvent(\"FLATTEN\", \"phase=requested\",",
        "WriteDebugEvent(\"TRANSPORT_BIND\",",
        "WriteDebugEvent(\"TRANSPORT_RELEASE\",",
        "WriteDebugEvent(\"PROTECTIVE_REPLACE_BEGIN\",",
        "WriteDebugEvent(\"PROTECTIVE_REPLACE_END\",",
        "WriteDebugEvent(\"PROTECTIVE_REPLACE_FAIL\",",
        "WriteDebugEvent(\"PROTECTIVE_REPLACE_COMMIT\",",
        "WriteDebugEvent(\"STATE_SAVE_ERROR\", $\"msg={ex.Message}\")",
        "WriteDebugEvent(\"STATE_RESTORE_ERROR\", $\"msg={ex.Message}\")"
      ]
    }
  },
  "notes": "SecondLegAdvanced now emits Mancini-style runtime debug/risk logs plus a dedicated pattern and trade lifecycle lane. This contract freezes the current source-level schema and vocabulary so observability drift is caught quickly."
}
